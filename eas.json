{
  "cli": {
    "version": ">= 16.19.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
"env": {
  "EXPO_PUBLIC_API_URL": "https://api.swiftpasstech.com/api",
  "EXPO_PUBLIC_MEDIA_URL": "https://swiftpasstech.com"
}
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "aab"
      },
      "distribution": "internal",
"env": {
  "EXPO_PUBLIC_API_URL": "https://api.swiftpasstech.com/api",
  "EXPO_PUBLIC_MEDIA_URL": "https://swiftpasstech.com"
}
    }
  },
  "submit": {
    "production": {}
  }
}