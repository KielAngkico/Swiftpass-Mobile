{
  "cli": {
    "version": ">= 16.19.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "android": { "buildType": "apk" },
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.swiftpasstech.com/api",
        "EXPO_PUBLIC_MEDIA_URL": "https://api.swiftpasstech.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}